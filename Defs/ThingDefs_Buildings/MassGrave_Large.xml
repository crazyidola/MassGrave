<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>MassGrave_Large</defName>
    <label>大規模な墓</label>
    <description>通常より大きな墓。3×2サイズ。</description>

    <inspectorTabs>
      <li>MassGrave.ITab_MassGrave</li>
    </inspectorTabs>

    <thingClass>MassGrave.Building_MassGrave</thingClass>

    <size>(3,2)</size>
    <interactionCellOffset>(0, -1, 0)</interactionCellOffset>

    <graphicData>
      <texPath>Things/Building/MassGrave_Large</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(3,2)</drawSize>
      <drawRotated>true</drawRotated>
    </graphicData>

    <stuffCategories>
      <li>Stony</li>
    </stuffCategories>

    <costStuffCount>200</costStuffCount>

    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>

    <designationCategory>Misc</designationCategory>

    <!-- isJoySource は削除（1.4以降は存在しない） -->
  </ThingDef>
</Defs>
